define void @without_flag_i32_v2i16(ptr %base) {
; NO-FLAG-LABEL: @without_flag_i32_v2i16(
; NO-FLAG-NEXT:  entry:
; NO-FLAG-NEXT:    [[PTR1:%.*]] = getelementptr i32, ptr [[BASE:%.*]], i64 1
; NO-FLAG-NEXT:    [[V0:%.*]] = load i32, ptr [[BASE]], align 4
; NO-FLAG-NEXT:    [[V1:%.*]] = load <2 x i16>, ptr [[PTR1]], align 4
; NO-FLAG-NEXT:    ret void
;
entry:
  %ptr1 = getelementptr i32, ptr %base, i64 1
  %v0 = load i32, ptr %base, align 4
  %v1 = load <2 x i16>, ptr %ptr1, align 4
